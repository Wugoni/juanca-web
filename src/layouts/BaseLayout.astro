---
const { title = 'Juan Carlos Sánchez Pérez', description = 'Programador web senior' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root{--bg:#0a0f1c;--bg2:#0f172a;--card:#111b34;--line:#26304e;--txt:#e8efff;--muted:#a9b4d0;--acc:#7dd3fc;--acc2:#a78bfa;--shadow:0 24px 80px rgba(0,0,0,.35)}
      *{box-sizing:border-box} html{scroll-behavior:smooth} body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:radial-gradient(circle at top,#182343 0,#0b1020 42%,#070b15 100%);color:var(--txt)}
      a{color:inherit;text-decoration:none} img{max-width:100%;display:block}
      .wrap{width:min(1120px,92vw);margin:0 auto}
      header{position:sticky;top:0;z-index:20;backdrop-filter:blur(18px);background:rgba(7,11,21,.45);border-bottom:1px solid rgba(255,255,255,.08)}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:16px 0;gap:16px}
      .brand{font-weight:800}
      .menu{display:flex;gap:18px;flex-wrap:wrap;color:var(--muted);font-size:.95rem}
      .menu a:hover{color:#fff}
      .pill{border:1px solid rgba(255,255,255,.12);padding:10px 14px;border-radius:999px;background:rgba(255,255,255,.04)}
      .btn{padding:14px 18px;border-radius:14px;font-weight:700;border:1px solid rgba(255,255,255,.12);transition:transform .2s ease,box-shadow .2s ease}
      .btn:hover{transform:translateY(-1px);box-shadow:0 12px 30px rgba(0,0,0,.25)}
      .btn.primary{background:linear-gradient(135deg,var(--acc),var(--acc2));color:#08101f;box-shadow:0 12px 30px rgba(125,211,252,.18)}
      .btn.ghost{background:rgba(255,255,255,.03)}
      .card{background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.035));border:1px solid rgba(255,255,255,.10);border-radius:28px;padding:28px;box-shadow:var(--shadow);backdrop-filter:blur(14px)}
      .tag{padding:10px 12px;border-radius:999px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);color:#dfe8ff;font-size:.95rem}
      h1{font-size:clamp(2.2rem,5vw,4.6rem);line-height:.98;letter-spacing:-.04em;margin:14px 0 16px;max-width:11ch}
      h2{font-size:1.55rem;margin:0 0 16px}
      p,li{color:var(--muted);line-height:1.72}
      .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
      .section-gap{margin-top:20px}
      .timeline{display:grid;gap:14px}
      .job{padding:18px;border-radius:18px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.08)}
      .hero{display:grid;grid-template-columns:1.05fr .95fr;gap:28px;align-items:center;padding:64px 0 24px}
      .lead{font-size:1.08rem;max-width:58ch}
      .actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:24px}
      .hero-card{padding:0;overflow:hidden;border-radius:34px}
      .hero-card img{width:100%;height:650px;object-fit:cover;object-position:center center;filter:contrast(1.08) brightness(1.03) saturate(1.02)}
      .chips{display:flex;flex-wrap:wrap;gap:10px}
      .contact-form{display:grid;gap:10px;margin-top:14px}
      .contact-form input,.contact-form textarea{padding:12px 14px;border-radius:12px;border:1px solid var(--line);background:#0d1426;color:var(--txt)}
      .footer{padding:34px 0 48px;color:var(--muted);text-align:center;font-size:.95rem}
      @media (max-width: 900px){.grid-2,.hero{grid-template-columns:1fr}.menu{display:none}h1{max-width:none}.hero-card img{height:520px}}
    </style>
  </head>
  <body>
    <header>
      <div class="wrap nav">
        <div class="brand">Juan Carlos Sánchez Pérez</div>
        <nav class="menu">
          <a href="#about">Sobre mí</a>
          <a href="#stack">Stack</a>
          <a href="#experience">Experiencia</a>
          <a href="#education">Formación</a>
          <a href="#contact">Contacto</a>
        </nav>
        <div class="pill">ES / EN</div>
      </div>
    </header>
    <main class="wrap"><slot /></main>
    <footer class="footer wrap">© {new Date().getFullYear()} Juan Carlos Sánchez Pérez</footer>
  </body>
</html>
